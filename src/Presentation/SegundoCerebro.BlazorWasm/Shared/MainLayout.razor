@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider Theme="_currentTheme" @bind-IsDarkMode="_isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@((e) => DrawerToggle())" />
        <MudIcon Icon="@Icons.Material.Filled.Psychology" Size="Size.Large" Class="ml-2 mr-2" />
        <MudText Typo="Typo.h5" Style="font-weight: 700;">SegundoCerebro</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleDarkMode" Title="Cambiar Tema" />
        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" Class="mr-4" />
        <MudAvatar Color="Color.Secondary" Variant="Variant.Filled">J</MudAvatar>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <div class="mt-4"></div>
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="background-color: var(--mud-palette-background-grey); min-height: 100vh;">
        <MudContainer MaxWidth="MaxWidth.Large" Class="pt-6 pb-12">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _isDarkMode = false;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    void ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
    }

    private MudTheme _currentTheme = new MudTheme()
    {
        Palette = new PaletteLight()
        {
            Primary = "#512BD4", // Color morado corporativo de tu README
            Secondary = "#10b981", // Verde esmeralda para acentos
            AppbarBackground = "#512BD4",
            Background = "#f4f6f8", // Gris muy sutil para contraste
            DrawerBackground = "#ffffff"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#7c5cdb", // Morado un poco más claro para modo oscuro
            Secondary = "#10b981",
            AppbarBackground = "#1e1e2d",
            Background = "#1a1a27",
            Surface = "#1e1e2d",
            DrawerBackground = "#1a1a27",
            TextPrimary = "#ffffff",
            TextSecondary = "#b2b0bf"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px" // Bordes redondeados en toda la app
        }
    };
}