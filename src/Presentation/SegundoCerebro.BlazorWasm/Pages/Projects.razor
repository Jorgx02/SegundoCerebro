@page "/projects"
@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Models.Enums
@using SegundoCerebro.BlazorWasm.Services
@using SegundoCerebro.BlazorWasm.Components.Dialogs
@inject IProjectService ProjectService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Projects - SegundoCerebro</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid>
        <MudItem xs="12" Class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.h4">Projects</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog">
                New Project
            </MudButton>
        </MudItem>
    </MudGrid>

    <MudCard Elevation="4" Class="rounded-lg">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex justify-space-between align-center">
                    <MudText Typo="Typo.h6">All Projects</MudText>
                    <MudSelect T="ProjectStatus?" Value="statusFilter" ValueChanged="OnStatusFilterChanged"
                               Label="Filter by Status" Variant="Variant.Text" Margin="Margin.Dense" Dense="true"
                               Style="max-width: 150px;" Class="ml-auto" AnchorOrigin="Origin.BottomRight"
                               TransformOrigin="Origin.TopRight" Clearable="true">
                        @foreach (ProjectStatus status in Enum.GetValues<ProjectStatus>())
                        {
                            <MudSelectItem Value="@((ProjectStatus?)status)">@status.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudTable Items="@projects" Hover="true" Striped="true" Dense="true" Elevation="0" Loading="@loading"
                      LoadingProgressColor="Color.Info">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Due Date</MudTh>
                    <MudTh>Created</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudText Typo="Typo.body1">@context.Name</MudText>
                        @if (!string.IsNullOrEmpty(context.Description))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Description</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)">
                            @context.StatusName
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Due Date">@(context.DueDate?.ToString("d") ?? "-")</MudTd>
                    <MudTd DataLabel="Created">@context.CreatedAt.ToString("d")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                       OnClick="() => OpenEditDialog(context)" Class="mr-2" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="() => DeleteProject(context)"
                                       Disabled="@(context.Status == ProjectStatus.Completed)" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>No projects found matching the current filter.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private List<ProjectDto> projects = new();
    private bool loading = true;
    private ProjectStatus? statusFilter = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        loading = true;
        try
        {
            var result = await ProjectService.GetAllAsync(statusFilter);
            projects = result?.ToList() ?? new List<ProjectDto>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading projects: {ex.Message}", MudSeverity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnStatusFilterChanged(ProjectStatus? newStatus)
    {
        statusFilter = newStatus;
        await LoadProjects();
    }

    private async Task OpenCreateDialog()
    {
        var dialog = DialogService.Show<CreateProjectDialog>("Create New Project");
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is ProjectDto newProject)
        {
            projects.Insert(0, newProject);
            StateHasChanged();
        }
    }

    private async Task OpenEditDialog(ProjectDto projectToEdit)
    {
        var parameters = new DialogParameters { ["ProjectToEdit"] = projectToEdit };
        var dialog = DialogService.Show<EditProjectDialog>("Edit Project", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is ProjectDto updatedProject)
        {
            var index = projects.FindIndex(p => p.Id == updatedProject.Id);
            if (index != -1)
            {
                projects[index] = updatedProject;
                Snackbar.Add("Project updated successfully!", MudSeverity.Success);
                StateHasChanged();
            }
        }
    }

    private async Task DeleteProject(ProjectDto projectToDelete)
    {
        var parameters = new DialogParameters
        {
            ["ContentText"] = $"¿Estas seguro de querer eliminar el proyecto '{projectToDelete.Name}'? Este proyecto tiene tareas asociadas a el.",
            ["ButtonText"] = "Delete",
            ["ButtonColor"] = Color.Error
        };
        var dialog = DialogService.Show<ConfirmationDialog>("Delete Project", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                await ProjectService.DeleteAsync(projectToDelete.Id);
                projects.Remove(projectToDelete);
                Snackbar.Add("Project deleted successfully.", MudSeverity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting project: {ex.Message}", MudSeverity.Error);
            }
        }
    }

    private Color GetStatusColor(ProjectStatus status) => status switch
    {
        ProjectStatus.Completed => Color.Success,
        ProjectStatus.InProgress => Color.Info,
        ProjectStatus.OnHold => Color.Warning,
        ProjectStatus.Cancelled => Color.Error,
        _ => Color.Default
    };
}