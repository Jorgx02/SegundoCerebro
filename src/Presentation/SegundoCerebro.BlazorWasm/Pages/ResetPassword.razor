@page "/reset-password"
@attribute [AllowAnonymous]
@layout EmptyLayout
@using SegundoCerebro.BlazorWasm.Services
@using SegundoCerebro.BlazorWasm.Models.Auth
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Restablecer contraseña</PageTitle>

<MudCard Elevation="4" Class="pa-6 rounded-lg">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight: bold;">Nueva contraseña</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Token))
        {
            <MudAlert Severity="MudSeverity.Error">Enlace de recuperación no válido o caducado.</MudAlert>
        }
        else
        {
            <MudForm @ref="form">
                <MudTextField @bind-Value="model.NewPassword" Label="Nueva contraseña" InputType="InputType.Password"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" Required="true" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="Submit"
                           Disabled="@loading" Class="mt-2 py-2">
                    @if (loading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    }
                    else
                    {

                        <span>Guardar
                            contraseña</span>
                        }
                    </MudButton>
                </MudForm>
            }
        </MudCardContent>
    </MudCard>

@code {
    [SupplyParameterFromQuery][Parameter] public string? Email { get; set; }
    [SupplyParameterFromQuery][Parameter] public string? Token { get; set; }

    private ResetPasswordDto model = new();
    private MudForm form = null!;
    private bool loading = false;

    protected override void OnParametersSet()
    {
        model.Email = Email ?? "";
        model.Token = Token ?? "";
    }

    private async Task Submit()
    {
        await form.Validate();
        if (!form.IsValid) return;
        loading = true;
        try
        {
            await AuthService.ResetPasswordAsync(model); Snackbar.Add("Contraseña cambiada con éxito.", MudSeverity.Success);
            NavigationManager.NavigateTo("/login");
        }
        catch { Snackbar.Add("El enlace ha caducado o la contraseña no cumple los requisitos.", MudSeverity.Error); }
        finally
        {
            loading = false;
        }
    }
}
