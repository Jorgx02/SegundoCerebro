@page "/accounts"
@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Models.Enums
@using SegundoCerebro.BlazorWasm.Services
@inject IAccountService AccountService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@* Título de la página que se mostrará en la pestaña del navegador. *@
<PageTitle>Cuentas - SegundoCerebro</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid>
        <MudItem xs="12" Class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.h4">Cuentas</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog">
                Nueva Cuenta
            </MudButton>
        </MudItem>
    </MudGrid>

    @* Tarjetas de resumen que muestran métricas clave sobre las cuentas. *@
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="3" Class="rounded-lg">
                <MudCardContent>
                    <div class="d-flex justify-space-between">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Saldo total</MudText>
                            <MudText Typo="Typo.h5" Color="@(totalBalance >= 0 ? Color.Success : Color.Error)">
                                @totalBalance.ToString("N2")
                            </MudText>
                        </div>
                        <MudIcon Icon="Icons.Material.Filled.AccountBalance" Size="Size.Large" Color="Color.Primary" />
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="3" Class="rounded-lg">
                <MudCardContent>
                    <div class="d-flex justify-space-between">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Cuentas activas</MudText>
                            <MudText Typo="Typo.h5">@allAccounts.Count(a => a.IsActive)</MudText>
                        </div>
                        <MudIcon Icon="Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large"
                                 Color="Color.Secondary" />
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="3" Class="rounded-lg">
                <MudCardContent>
                    <div class="d-flex justify-space-between">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Normal</MudText>
                            <MudText Typo="Typo.h6">
                                @allAccounts.Where(a => a.IsActive && a.Type == AccountType.Checking).Sum(a =>
                                a.Balance).ToString("N2")
                            </MudText>
                        </div>
                        <MudIcon Icon="Icons.Material.Filled.Payment" Size="Size.Large" Color="Color.Info" />
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="3" Class="rounded-lg">
                <MudCardContent>
                    <div class="d-flex justify-space-between">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Ahorros</MudText>
                            <MudText Typo="Typo.h6">
                                @allAccounts.Where(a => a.IsActive && a.Type == AccountType.Savings).Sum(a =>
                                a.Balance).ToString("N2")
                            </MudText>
                        </div>
                        <MudIcon Icon="Icons.Material.Filled.Savings" Size="Size.Large" Color="Color.Success" />
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* Tabla principal que muestra la lista de todas las cuentas. *@
    <MudCard Elevation="4" Class="rounded-lg">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex justify-space-between align-center">
                    <MudText Typo="Typo.h6">Todas las cuentas</MudText>
                    <MudSelect T="AccountStatusFilter" Value="statusFilter" ValueChanged="OnStatusFilterChanged"
                               Label="Tipo de cuenta" Variant="Variant.Text" Margin="Margin.Dense" Dense="true"
                               Style="max-width: 110px;" Class="ml-auto" AnchorOrigin="Origin.BottomRight"
                               TransformOrigin="Origin.TopRight">
                        <MudSelectItem Value="AccountStatusFilter.Active">Activas</MudSelectItem>
                        <MudSelectItem Value="AccountStatusFilter.Inactive">Inactivas</MudSelectItem>
                        <MudSelectItem Value="AccountStatusFilter.All">Todas</MudSelectItem>
                    </MudSelect>
                </div>
            </CardHeaderContent>
        </MudCardHeader>
        @* Contenido de la tarjeta que alberga la tabla de cuentas. *@
        <MudCardContent>
            <MudTable Items="@FilteredAccounts" Hover="true" Striped="true" Dense="true" Elevation="0"
                      Loading="@loading" LoadingProgressColor="Color.Info">
                <HeaderContent>
                    <MudTh>Nombre</MudTh>
                    <MudTh>Tipo</MudTh>
                    <MudTh>Balance</MudTh>
                    <MudTh>Banco</MudTh>
                    <MudTh>Estado</MudTh>
                    <MudTh>Acciones</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        @* Celda que muestra el nombre, descripción e icono de la cuenta. *@
                        <div class="d-flex align-center">
                            <MudIconButton
                            Icon="@(context.IsFavorite ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)"
                            Color="Color.Warning" Size="Size.Small" OnClick="() => ToggleFavoriteStatus(context)"
                            Class="mr-1" />
                            <MudIcon Icon="@GetAccountIcon(context.Type)" Class="mr-3" />
                            <div>
                                <MudLink Href="@($"/accounts/{context.Id}")" Typo="Typo.body1" Color="Color.Default"
                                         Underline="Underline.None">
                                    @context.Name
                                </MudLink>
                                @if (!string.IsNullOrEmpty(context.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Description</MudText>
                                }
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Tipo">
                        @* Chip de color para identificar visualmente el tipo de cuenta. *@
                        <MudChip Size="Size.Small" Color="@GetTypeColor(context.Type)">
                            @context.TypeName
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Balance">
                        <MudText Typo="Typo.body1" Color="@(context.Balance >= 0 ? Color.Success : Color.Error)">
                            @context.Balance.ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Banco">@(context.BankName ?? "-")</MudTd>
                    <MudTd DataLabel="Estado">
                        @* Chip de color para indicar si la cuenta está activa o inactiva. *@
                        <MudChip Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                            @(context.IsActive ? "Activa" : "Inactiva")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        @* Botones de acción para editar y eliminar (desactivar) una cuenta. *@
                        <MudIconButton Icon="Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                       Variant="Variant.Filled" Class="mr-2" OnClick="() => OpenEditDialog(context)" />
                        <MudIconButton Icon="Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       Variant="Variant.Filled" OnClick="() => DeleteAccount(context)" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    /// <summary>
    /// Lista que almacena todas las cuentas obtenidas del servicio.
    /// </summary>
    private List<AccountDto> allAccounts = new();

    /// <summary>
    /// Almacena el saldo total combinado de todas las cuentas activas.
    /// </summary>
    private decimal totalBalance = 0;

    /// <summary>
    /// Indicador booleano para controlar el estado de carga de la tabla.
    /// </summary>
    private bool loading = true;

    /// <summary>
    /// Almacena el valor actual del filtro de estado de la cuenta (Activas, Inactivas, Todas).
    /// </summary>
    private AccountStatusFilter statusFilter = AccountStatusFilter.Active;

    /// <summary>
    /// Enumeración para definir los posibles estados de filtro de la tabla de cuentas.
    /// </summary>
    private enum AccountStatusFilter { All, Active, Inactive }

    /// <summary>
    /// Se ejecuta cuando el usuario cambia el valor del filtro de estado.
    /// </summary>
    private void OnStatusFilterChanged(AccountStatusFilter newValue)
    {
        statusFilter = newValue;
        StateHasChanged();
    }

    /// <summary>
    /// Propiedad computada que devuelve la lista de cuentas filtrada según el valor de `statusFilter`.
    /// </summary>
    private IEnumerable<AccountDto> FilteredAccounts
    {
        get
        {
            var accounts = statusFilter switch
            {
                AccountStatusFilter.Active => allAccounts.Where(a => a.IsActive),
                AccountStatusFilter.Inactive => allAccounts.Where(a => !a.IsActive),
                _ => allAccounts
            };
            return accounts.OrderByDescending(a => a.IsFavorite).ThenBy(a => a.Name);
        }
    }

    /// <summary>
    /// Método del ciclo de vida de Blazor que se ejecuta al inicializar la página.
    /// Llama a `LoadAccounts` para cargar los datos iniciales.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();
    }

    /// <summary>
    /// Carga todas las cuentas desde el servicio API, calcula el balance total
    /// y gestiona el estado de carga de la UI.
    /// </summary>
    private async Task LoadAccounts()
    {
        loading = true;
        try
        {
            var result = await AccountService.GetAllAsync();
            allAccounts = result?.ToList() ?? new List<AccountDto>();
            totalBalance = await AccountService.GetTotalBalanceAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cargando cuentas: {ex.Message}", MudSeverity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    /// <summary>
    /// Llama al servicio para cambiar el estado de favorito de una cuenta y actualiza la UI.
    /// </summary>
    /// <param name="account">La cuenta a modificar.</param>
    private async Task ToggleFavoriteStatus(AccountDto account)
    {
        try
        {
            await AccountService.ToggleFavoriteAsync(account.Id);
            account.IsFavorite = !account.IsFavorite; // Actualiza el estado local para reflejo inmediato en la UI
            Snackbar.Add("Estado de favorito actualizado.", MudSeverity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error actualizando el estado de favorito: {ex.Message}", MudSeverity.Error);
        }
        // StateHasChanged se invoca automáticamente por el evento OnClick
    }

    /// <summary>
    /// Devuelve el icono correspondiente a un tipo de cuenta.
    /// </summary>
    /// <param name="type">El tipo de cuenta.</param>
    private String GetAccountIcon(AccountType type) => type switch
    {
        AccountType.Checking => Icons.Material.Filled.Payment,
        AccountType.Savings => Icons.Material.Filled.Savings,
        AccountType.Investment => Icons.Material.Filled.TrendingUp,
        AccountType.Cash => Icons.Material.Filled.Money,
        _ => Icons.Material.Filled.AccountBalance
    };

    /// <summary>
    /// Devuelve el color de MudBlazor correspondiente a un tipo de cuenta para usar en los chips.
    /// </summary>
    /// <param name="type">El tipo de cuenta.</param>
    private Color GetTypeColor(AccountType type) => type switch
    {
        AccountType.Checking => Color.Primary,
        AccountType.Savings => Color.Info,
        AccountType.Investment => Color.Secondary,
        AccountType.Cash => Color.Success,
        _ => Color.Default
    };

    /// <summary>
    /// Abre el diálogo para crear una nueva cuenta.
    /// Si la creación es exitosa, recarga la lista de cuentas.
    /// </summary>
    private async Task OpenCreateDialog()
    {
        var dialog = DialogService.Show<CreateAccountDialog>("Crear nueva cuenta");
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadAccounts();
            Snackbar.Add("Cuenta creada con éxito", MudSeverity.Success);
        }
    }

    /// <summary>
    /// Abre el diálogo para editar una cuenta existente.
    /// </summary>
    /// <param name="account">La cuenta a editar.</param>
    /// <remarks>Si la edición es exitosa, recarga la lista de cuentas.</remarks>
    private async Task OpenEditDialog(AccountDto account)
    {
        var parameters = new DialogParameters { ["Account"] = account };
        var dialog = DialogService.Show<EditAccountDialog>("Editar cuenta", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadAccounts();
            Snackbar.Add("Cuenta actualizada con éxito", MudSeverity.Success);
        }
    }

    /// <summary>
    /// Gestiona la lógica para desactivar (soft delete) una cuenta.
    /// - Si la cuenta tiene saldo positivo, abre un diálogo para transferir los fondos.
    // - Si tiene saldo cero, pide confirmación para desactivarla.
    /// </summary>
    /// <param name="account">La cuenta a desactivar.</param>
    private async Task DeleteAccount(AccountDto account)
    {
        if (account.Balance < 0)
        {
            Snackbar.Add("No se puede desactivar una cuenta con saldo negativo.", MudSeverity.Error);
            return;
        }

        if (!account.IsActive && account.Balance == 0)
        {
            Snackbar.Add("La cuenta ya se encuentra inactiva y vacía.", MudSeverity.Info);
            return;
        }

        if (account.Balance > 0)
        {
            var parameters = new DialogParameters
            {
                ["AccountToDelete"] = account,
                ["AvailableAccounts"] = allAccounts.Where(a => a.Id != account.Id && a.IsActive).ToList()
            };
            var dialog = DialogService.Show<TransferAndDeleteDialog>("Transferir fondos y desactivar", parameters);
            var dialogResult = await dialog.Result;
            if (!dialogResult.Canceled) await LoadAccounts();
            return;
        }

        bool? result = await DialogService.ShowMessageBox(
            "Desactivar cuenta",
            $"¿Estás seguro de que deseas desactivar la cuenta '{account.Name}'?",
            yesText: "Desactivar",
            cancelText: "Cancelar");

        if (result == true)
        {
            try
            {
                var updateDto = new UpdateAccountDto
                {
                    Name = account.Name,
                    Description = account.Description,
                    Type = account.Type,
                    Currency = account.Currency,
                    AccountNumber = account.AccountNumber,
                    BankName = account.BankName,
                    IsActive = false,
                    Balance = 0
                };
                await AccountService.UpdateAsync(account.Id, updateDto);

                await LoadAccounts();
                Snackbar.Add("Cuenta desactivada correctamente.", MudSeverity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error al desactivar la cuenta: {ex.Message}", MudSeverity.Error);
            }
        }
    }

