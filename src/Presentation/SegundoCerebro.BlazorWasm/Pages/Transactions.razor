@page "/transactions"
@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Models.Enums
@using SegundoCerebro.BlazorWasm.Services
@inject ITransactionService TransactionService
@inject IAccountService AccountService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Transacciones - SegundoCerebro</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid>
        <MudItem xs="12" Class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.h4">Transacciones</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog">
                Nueva transacción
            </MudButton>
        </MudItem>
    </MudGrid>

    <!-- Filters -->
    <MudCard Elevation="3" Class="mb-4 rounded-lg">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="Fecha de inicio" @bind-Date="startDate" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="Fecha de fin" @bind-Date="endDate" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="Guid?" Label="Cuenta" @bind-Value="selectedAccountId">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">Todas las cuentas</MudSelectItem>
                        @foreach (var account in accounts)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)account.Id)">@account.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="TransactionType?" Label="Tipo" @bind-Value="selectedType">
                        <MudSelectItem T="TransactionType?" Value="@((TransactionType?)null)">All Types</MudSelectItem>
                        <MudSelectItem T="TransactionType?" Value="@((TransactionType?)TransactionType.Income)">Ingreso
                        </MudSelectItem>
                        <MudSelectItem T="TransactionType?" Value="@((TransactionType?)TransactionType.Expense)">Gasto
                        </MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    <!-- Transactions Table -->
    <MudCard Elevation="4" Class="rounded-lg">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Todas las transacciones (@filteredTransactions.Count())</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudTable Items="@filteredTransactions" Hover="true" Striped="true" Dense="true" Elevation="0"
                      Loading="@loading" LoadingProgressColor="Color.Info">
                <HeaderContent>
                    <MudTh>Fecha</MudTh>
                    <MudTh>Descripción</MudTh>
                    <MudTh>Categoría</MudTh>
                    <MudTh>Cuenta</MudTh>
                    <MudTh>Monto</MudTh>
                    <MudTh>Tipo</MudTh>
                    <MudTh>Editar transacción</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Fecha">
                        <MudText Typo="Typo.body2">@context.Date.ToString("dd/MM/yyyy")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Descripción">
                        <div>
                            <MudText Typo="Typo.body2">@context.Description</MudText>
                            @if (!string.IsNullOrEmpty(context.Reference))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Ref: @context.Reference</MudText>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Categoría">
                        <div class="d-flex align-center">
                            @if (!string.IsNullOrEmpty(context.CategoryIcon))
                            {
                                <MudIcon Icon="@context.CategoryIcon" Size="Size.Small" Class="mr-2" />
                            }
                            <MudText Typo="Typo.body2">@context.CategoryName</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Cuenta">
                        <MudText Typo="Typo.body2">@context.AccountName</MudText>
                    </MudTd>
                    <MudTd DataLabel="Monto">
                        <MudText Typo="Typo.body2"
                                 Color="@(context.Type == TransactionType.Income ? Color.Success : Color.Error)">
                            @context.FormattedAmount
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Tipo">
                        <MudChip Size="Size.Small"
                                 Color="@(context.Type == TransactionType.Income ? Color.Success : Color.Error)">
                            @context.TypeName
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Acciones">
                        <MudIconButton Icon="Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                       Variant="Variant.Filled" OnClick="() => OpenEditDialog(context)" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>Ninguna transacción encontrada</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private List<TransactionDto> transactions = new();
    private List<AccountDto> accounts = new();
    private bool loading = true;

    // Filters
    private DateTime? startDate = DateTime.Today.AddDays(-30);
    private DateTime? endDate = DateTime.Today;
    private Guid? selectedAccountId;
    private TransactionType? selectedType;

    private IEnumerable<TransactionDto> filteredTransactions => transactions.Where(t =>
            (!startDate.HasValue || t.Date >= startDate.Value) &&
            (!endDate.HasValue || t.Date <= endDate.Value) &&
            (!selectedAccountId.HasValue || t.AccountId == selectedAccountId.Value) &&
            (!selectedType.HasValue || t.Type == selectedType.Value));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        try
        {
            var transactionsTask = TransactionService.GetAllAsync();
            var accountsTask = AccountService.GetAllAsync();

            await Task.WhenAll(transactionsTask, accountsTask);

            transactions = (await transactionsTask).ToList();
            accounts = (await accountsTask).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cargando los datos: {ex.Message}", MudSeverity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var dialog = DialogService.Show<CreateTransactionDialog>("Crear nueva transacción");
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
            Snackbar.Add("Transacción creada con éxito", MudSeverity.Success);
        }
    }

    private async Task OpenEditDialog(TransactionDto transaction)
    {
        var parameters = new DialogParameters { ["Transaction"] = transaction };
        var dialog = DialogService.Show<EditTransactionDialog>("Editar transacción", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
            Snackbar.Add("Transacción actualizada con éxito", MudSeverity.Success);
        }
    }
}