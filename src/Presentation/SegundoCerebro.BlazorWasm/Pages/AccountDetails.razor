@page "/accounts/{AccountId}"
@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Services
@using SegundoCerebro.BlazorWasm.Models.Enums
@using SegundoCerebro.BlazorWasm.Shared
@using SegundoCerebro.BlazorWasm.Components.Dialogs
@inject IAccountService AccountService
@inject ICardService CardService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>Detalles de la cuenta - SegundoCerebro</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @if (loading)
    {
        <div class="d-flex justify-center align-center" style="height: 50vh;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (account != null)
    {
        <MudGrid>
            <MudItem xs="12">
                <MudBreadcrumbs Items="_breadcrumbs"></MudBreadcrumbs>
            </MudItem>
            <MudItem xs="12" Class="d-flex align-center">
                <MudChip Size="Size.Small" Color="@(account.IsActive ? Color.Success : Color.Default)" Class="mr-4">
                    @(account.IsActive ? "Activa" : "Inactiva")
                </MudChip>
                <MudText Typo="Typo.h4">@account.Name</MudText>
                <MudSpacer />
                <MudText Typo="Typo.h5" Color="@(account.Balance >= 0 ? Color.Success : Color.Error)">
                    @account.Balance.ToString("C")
                </MudText>
            </MudItem>
            @if (!string.IsNullOrEmpty(account.Description))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Color="Color.Secondary">@account.Description</MudText>
                </MudItem>
            }
        </MudGrid>

        <MudDivider Class="my-6" />

        <MudGrid>
            <MudItem xs="12">
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h5">Tarjetas asociadas</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddCard"
                               OnClick="OpenAddCardDialog" Disabled="@(account.Type != AccountType.Checking)">
                        Añadir tarjeta
                    </MudButton>
                </div>

                @if (cards.Any())
                {
                    <MudList Clickable="false">
                        @foreach (var card in cards)
                        {
                            <MudListItem>
                                <div class="d-flex align-center" style="width: 100%;">
                                    <MudIcon Icon="@GetCardIcon(card.Brand)" Class="mr-4" />
                                    <div>
                                        <MudText Typo="Typo.body1">@card.Name</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @card.Brand - terminada en @card.Last4Digits
                                        </MudText>
                                    </div>
                                    <MudSpacer />
                                    <MudText Typo="Typo.body2">Expira: @card.ExpirationMonth.ToString("D2")/@card.ExpirationYear
                                    </MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="() => OpenEditCardDialog(card)" Class="ml-4" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="() => DeleteCard(card)" Class="ml-1" />
                                </div>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                }
                else
                {
                    <MudPaper Elevation="0" Class="pa-4 rounded-lg"
                              Style="background-color: var(--mud-palette-background-grey);">
                        <MudText>Esta cuenta no tiene tarjetas asociadas.</MudText>
                        @if (account.Type != AccountType.Checking)
                        {
                            <MudAlert Severity="MudBlazor.Severity.Info" Class="mt-4" Elevation="0">
                                Las tarjetas solo se pueden asociar a cuentas de tipo "Normal".
                            </MudAlert>
                        }
                    </MudPaper>
                }
            </MudItem>
        </MudGrid>
    }
    else
    {
        <MudAlert Severity="MudBlazor.Severity.Error">Cuenta no encontrada.</MudAlert>
    }
</MudContainer>

@code {
    [Parameter]
    public string AccountId { get; set; } = string.Empty;

    private AccountDto? account;
    private List<CardDto> cards = new();
    private bool loading = true;
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        if (Guid.TryParse(AccountId, out var accountId))
        {
            await LoadData(accountId);
        }
        else
        {
            Snackbar.Add("ID de cuenta no válido.", MudSeverity.Error);
            loading = false;
        }
    }

    private async Task LoadData(Guid accountId)
    {
        loading = true;
        try
        {
            var accountTask = AccountService.GetByIdAsync(accountId);
            var cardsTask = CardService.GetByAccountIdAsync(accountId);

            await Task.WhenAll(accountTask, cardsTask);

            account = await accountTask;
            cards = (await cardsTask).ToList();

            if (account != null)
            {
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Cuentas", href: "/accounts"),
                    new BreadcrumbItem(account.Name, href: null, disabled: true)
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar los detalles de la cuenta: {ex.Message}", MudSeverity.Error);
            account = null;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OpenAddCardDialog()
    {
        if (account is null) return;

        var parameters = new DialogParameters { ["AccountId"] = account.Id };
        var dialog = DialogService.Show<AddCardDialog>("Añadir nueva tarjeta", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CardDto newCard)
        {
            cards.Add(newCard);
            Snackbar.Add("Tarjeta añadida con éxito.", MudSeverity.Success);
        }
    }

    private async Task OpenEditCardDialog(CardDto cardToEdit)
    {
        var parameters = new DialogParameters { ["CardToEdit"] = cardToEdit };
        var dialog = DialogService.Show<EditCardDialog>("Editar tarjeta", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is CardDto updatedCard)
        {
            var index = cards.FindIndex(c => c.Id == updatedCard.Id);
            if (index != -1)
            {
                cards[index] = updatedCard;
                Snackbar.Add("Tarjeta actualizada con éxito.", MudSeverity.Success);
            }
        }
    }

    private async Task DeleteCard(CardDto card)
    {
        var parameters = new DialogParameters
        {
            ["ContentText"] = $"¿Estás seguro de eliminar la tarjeta '{card.Name}' acabada en {card.Last4Digits}?",
            ["ButtonColor"] = Color.Error
        };
        var dialog = DialogService.Show<ConfirmationDialog>("Eliminar tarjeta", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                await CardService.DeleteAsync(card.Id);
                cards.Remove(card);
                Snackbar.Add("Tarjeta eliminada con éxito.", MudSeverity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error eliminando la tarjeta: {ex.Message}", MudSeverity.Error);
            }
        }
    }

    private string GetCardIcon(string brand) => brand.ToLower() switch
    {
        "visa" => CustomIcons.Visa,
        "mastercard" => CustomIcons.Mastercard,
        "amex" => CustomIcons.Amex,
        _ => Icons.Material.Filled.CreditCard
    };
}