@page "/todoitems"
@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Models.Enums
@using SegundoCerebro.BlazorWasm.Services
@using MudBlazor
@inject ITodoItemService TodoItemService
@inject ITimeLogService TimeLogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Todas las tareas - SegundoCerebro</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid>
        <MudItem xs="12" Class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.h4">Todas las tareas</MudText>
        </MudItem>
    </MudGrid>

    <MudCard Elevation="4" Class="rounded-lg">
        <MudTable Items="@tasks" Hover="true" Striped="true" Dense="true" Elevation="0" Loading="@loading"
                  LoadingProgressColor="Color.Info" GroupBy="@_groupDefinition"
                  GroupHeaderClass="mud-table-group-header-custom">
            <HeaderContent>
                <MudTh>Tareas</MudTh>
                <MudTh>Estado</MudTh>
                <MudTh>Prioridad</MudTh>
                <MudTh>Fecha de vencimiento</MudTh>
                <MudTh Style="text-align: center;">Tiempo</MudTh>
            </HeaderContent>
            <GroupHeaderTemplate>
                <MudTh colspan="5">
                    <MudText Typo="Typo.h6">@context.Key</MudText>
                </MudTh>
            </GroupHeaderTemplate>
            <RowTemplate>
                <MudTd DataLabel="Tarea">
                    <MudLink Href="@($"/projects/{context.ProjectId}")" Typo="Typo.body1" Color="Color.Default"
                             Underline="Underline.None" Disabled="@(context.ProjectId == null)">
                        @context.Title
                    </MudLink>
                    @if (!string.IsNullOrEmpty(context.Description))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Description</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Estado">
                    <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)">
                        @context.StatusName
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Prioridad">
                    <MudRating SelectedValue="context.Priority" ReadOnly="true" MaxValue="3"
                               FullIcon="@Icons.Material.Filled.Flag" EmptyIcon="@Icons.Material.Outlined.Flag" />
                </MudTd>
                <MudTd DataLabel="Fecha de vencimiento">
                    @if (context.DueDate.HasValue)
                    {
                        <MudChip Size="Size.Small" Icon="@Icons.Material.Filled.Event"
                                 Color="@(context.DueDate.Value.Date < DateTime.Today ? Color.Error : Color.Default)">
                            @context.DueDate.Value.ToString("MMM dd")
                        </MudChip>
                    }
                    else
                    {
                        <MudText>-</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Tiempo">
                    <div class="d-flex align-center justify-center">
                        <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small" Class="mr-1" />
                        <MudText Typo="Typo.caption">@FormatTimeSpan(context.TotalTimeTracked)</MudText>
                        <MudIconButton
                            Icon="@(context.IsCurrentlyTracking ? Icons.Material.Filled.StopCircle : Icons.Material.Filled.PlayCircle)"
                            Color="@(context.IsCurrentlyTracking ? Color.Error : Color.Success)"
                            Size="Size.Small"
                            OnClick="() => ToggleTimeTracking(context)"
                            Class="ml-2"
                            OnClickStopPropagation="true" />
                    </div>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>Ninguna tarea encontrada.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudCard>
</MudContainer>

@code {
    private List<TodoItemDto> tasks = new();
    private bool loading = true;

    private TableGroupDefinition<TodoItemDto> _groupDefinition = new()
    {
        Selector = t => t.ProjectName ?? "Tareas sin proyecto"
    };

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var result = await TodoItemService.GetAllAsync();
            tasks = result?.OrderBy(t => t.ProjectName).ThenByDescending(t => t.CreatedAt).ToList() ?? new List<TodoItemDto>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar las tareas: {ex.Message}", MudSeverity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ToggleTimeTracking(TodoItemDto task)
    {
        try
        {
            if (task.IsCurrentlyTracking)
            {
                var stoppedLog = await TimeLogService.StopAsync(task.Id);
                task.IsCurrentlyTracking = false;
                task.TotalTimeTracked += stoppedLog.Duration;
                Snackbar.Add($"Temporizador detenido para '{task.Title}'.", MudSeverity.Info);
            }
            else
            {
                await TimeLogService.StartAsync(task.Id);
                task.IsCurrentlyTracking = true;
                Snackbar.Add($"Temporizador iniciado para '{task.Title}'.", MudSeverity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", MudSeverity.Error);
        }
    }

    private string FormatTimeSpan(TimeSpan ts) => $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}";

    private Color GetStatusColor(TodoItemStatus status) => status switch
    {
        TodoItemStatus.Completed => Color.Success,
        TodoItemStatus.InProgress => Color.Info,
        TodoItemStatus.WaitingFor => Color.Warning,
        _ => Color.Default
    };
}