@page "/forgot-password"
@attribute [AllowAnonymous]
@layout EmptyLayout
@using SegundoCerebro.BlazorWasm.Services
@using SegundoCerebro.BlazorWasm.Models.Auth
@inject IAuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>Recuperar Contraseña</PageTitle>

<MudCard Elevation="4" Class="pa-6 rounded-lg">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight: bold;">Recuperar contraseña</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudText Typo="Typo.body2" Class="mb-4">Introduce tu correo electrónico y te enviaremos un enlace para
            restablecer tu contraseña.</MudText>
            <MudForm @ref="form">
                <MudTextField @bind-Value="model.Email" Label="Correo Electrónico" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Class="mb-4" Required="true" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="Submit"
                           Disabled="@loading" Class="mt-2 py-2">
                    @if (loading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    }
                    else
                    {

                        <span>Enviar
                            enlace</span>
                        }
                    </MudButton>
                </MudForm>
                <MudText Align="Align.Center" Class="mt-4">
                    <MudLink Href="/login">Volver al login</MudLink>
                </MudText>
            </MudCardContent>
        </MudCard>

@code {
    private ForgotPasswordDto model = new();
    private MudForm form = null!;
    private bool loading = false;

    private async Task Submit()
    {
        await form.Validate();
        if (!form.IsValid) return;
        loading = true; try { await AuthService.ForgotPasswordAsync(model); Snackbar.Add("Si el correo existe, recibirás un enlace pronto.", MudSeverity.Success); }
        catch { Snackbar.Add("Error al enviar el correo.", MudSeverity.Error); }
        finally { loading = false; }
    }
}