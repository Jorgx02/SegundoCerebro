@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Models.Enums
@using SegundoCerebro.BlazorWasm.Services
@inject IAccountService AccountService
@inject ISnackbar Snackbar

@* Diálogo modal para la edición de los datos básicos de una cuenta existente. *@
<MudDialog>
    <DialogContent>
        <MudForm Model="@model" @ref="@form">
            @* Campos del formulario para editar el nombre y la descripción. *@
            <MudCardContent>
                <MudTextField @bind-Value="model.Name" For="@(() => model.Name)" Immediately="true" Label="Account Name"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />

                <MudTextField @bind-Value="model.Description" For="@(() => model.Description)"
                              Label="Description (Optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />

            </MudCardContent>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled">Update Account</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>
    /// La cuenta que se va a editar. Se recibe como parámetro del diálogo.
    /// </summary>
    [Parameter] public AccountDto Account { get; set; } = null!;

    /// <summary>
    /// El modelo de datos (DTO) que se enlaza al formulario para actualizar la cuenta.
    /// </summary>
    private UpdateAccountDto model = new();

    /// <summary>
    /// Referencia al componente MudForm para poder invocar su validación.
    /// </summary>
    private MudForm form = null!;

    /// <summary>
    /// Se ejecuta al inicializar el componente.
    /// Rellena el modelo del formulario con los datos de la cuenta que se está editando.
    /// </summary>
    protected override void OnInitialized()
    {
        model.Name = Account.Name;
        model.Description = Account.Description;
        model.Type = Account.Type;
        model.Currency = Account.Currency;
        model.AccountNumber = Account.AccountNumber;
        model.BankName = Account.BankName;
        model.IsActive = Account.IsActive;
        model.Balance = Account.Balance;
    }

    /// <summary>
    /// Cierra el diálogo sin guardar cambios.
    /// </summary>
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    /// <summary>
    /// Valida el formulario y, si es válido, envía la solicitud de actualización al servicio.
    /// Cierra el diálogo en caso de éxito o muestra un error en caso de fallo.
    /// </summary>
    private async Task Submit()
    {
        await form.Validate();

        if (form.IsValid)
        {
            try
            {
                await AccountService.UpdateAsync(Account.Id, model);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error updating account: {ex.Message}", MudSeverity.Error);
            }
        }
    }
}