@using MudBlazor.Utilities

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Seleccionar un color</MudText>
    </TitleContent>
    <DialogContent>
        <MudColorPicker @bind-Value="SelectedColor"
                        PickerVariant="PickerVariant.Static"
                        ColorPickerView="ColorPickerView.Grid"
                        DisableToolbar="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Aceptar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public MudColor InitialColor { get; set; } = new MudColor(Colors.Blue.Default);

    private MudColor SelectedColor { get; set; } = new MudColor(Colors.Blue.Default);

    protected override void OnInitialized() => SelectedColor = InitialColor;
    void Submit() => MudDialog.Close(DialogResult.Ok(SelectedColor));
    void Cancel() => MudDialog.Cancel();
}