@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Models.Enums
@using SegundoCerebro.BlazorWasm.Services
@inject IProjectService ProjectService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Project</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@model" @ref="@form" ValidationDelay="0">
            <MudTextField @bind-Value="model.Name" For="@(() => model.Name)" Label="Project Name"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
            <MudTextField @bind-Value="model.Description" For="@(() => model.Description)"
                          Label="Description (Optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
            <MudDatePicker @bind-Date="model.DueDate" Label="Due Date (Optional)" Variant="Variant.Outlined"
                           Margin="Margin.Dense" />
            <MudSelect T="ProjectStatus" @bind-Value="model.Status" For="@(() => model.Status)" Label="Status"
                       Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (ProjectStatus status in Enum.GetValues<ProjectStatus>())
                {
                    <MudSelectItem Value="@status">@status.ToString()</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled">Update</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ProjectDto ProjectToEdit { get; set; } = null!;

    private UpdateProjectDto model = new();
    private MudForm form = null!;

    protected override void OnInitialized()
    {
        if (ProjectToEdit is not null)
        {
            model.Name = ProjectToEdit.Name;
            model.Description = ProjectToEdit.Description;
            model.DueDate = ProjectToEdit.DueDate;
            model.Status = ProjectToEdit.Status;
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        try
        {
            var updatedProject = await ProjectService.UpdateAsync(ProjectToEdit.Id, model);
            MudDialog.Close(DialogResult.Ok(updatedProject));
        }
        catch (Exception ex)
        {
            // Mostramos el error de la API (ej. "No se puede completar si hay tareas pendientes")
            Snackbar.Add($"Error updating project: {ex.Message}", MudSeverity.Error);
        }
    }

    void Cancel() => MudDialog.Cancel();
}