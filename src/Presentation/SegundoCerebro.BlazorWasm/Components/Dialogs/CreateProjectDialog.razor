@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Services
@inject IProjectService ProjectService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Create New Project</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@model" @ref="@form" ValidationDelay="0">
            <MudTextField @bind-Value="model.Name" For="@(() => model.Name)" Label="Project Name"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
            <MudTextField @bind-Value="model.Description" For="@(() => model.Description)"
                          Label="Description (Optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
            <MudDatePicker @bind-Date="model.DueDate" Label="Due Date (Optional)" Variant="Variant.Outlined"
                           Margin="Margin.Dense" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private CreateProjectDto model = new();
    private MudForm form = null!;

    private async Task Submit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        var newProject = await ProjectService.CreateAsync(model);
        Snackbar.Add("Project created successfully!", MudSeverity.Success);
        MudDialog.Close(DialogResult.Ok(newProject));
    }

    void Cancel() => MudDialog.Cancel();
}