@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Models.Commands
@using SegundoCerebro.BlazorWasm.Models.Enums
@using SegundoCerebro.BlazorWasm.Services
@inject ITodoItemService TodoItemService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Task</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@model" @ref="@form" ValidationDelay="0">
            <MudTextField @bind-Value="model.Title" For="@(() => model.Title)" Label="Task Title"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
            <MudTextField @bind-Value="model.Description" For="@(() => model.Description)"
                          Label="Description (Optional)" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
            <MudDatePicker @bind-Date="model.DueDate" Label="Due Date (Optional)" Variant="Variant.Outlined"
                           Margin="Margin.Dense" />
            <MudSelect T="TodoItemStatus" @bind-Value="model.Status" For="@(() => model.Status)" Label="Status"
                       Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (TodoItemStatus status in Enum.GetValues<TodoItemStatus>())
                {
                    <MudSelectItem Value="@status">@status.ToString()</MudSelectItem>
                }
            </MudSelect>
            <MudRating @bind-SelectedValue="model.Priority" MaxValue="3" FullIcon="@Icons.Material.Filled.Flag"
                       EmptyIcon="@Icons.Material.Outlined.Flag" Label="Priority" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled">Update Task</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public TodoItemDto TaskToEdit { get; set; } = null!;

    private UpdateTodoItemDto model = new();
    private MudForm form = null!;

    protected override void OnInitialized()
    {
        if (TaskToEdit is not null)
        {
            model.Title = TaskToEdit.Title;
            model.Description = TaskToEdit.Description;
            model.Status = TaskToEdit.Status;
            model.Priority = TaskToEdit.Priority;
            model.DueDate = TaskToEdit.DueDate;
            model.ProjectId = TaskToEdit.ProjectId;
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        var updatedTask = await TodoItemService.UpdateAsync(TaskToEdit.Id, model);
        MudDialog.Close(DialogResult.Ok(updatedTask));
    }

    void Cancel() => MudDialog.Cancel();
}
