@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Models.Enums
@using SegundoCerebro.BlazorWasm.Services
@inject ITransactionService TransactionService
@inject IAccountService AccountService
@inject ICategoryService CategoryService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (!allCategories.Any() || !accounts.Any(a => a.IsActive))
        {
            <MudAlert Severity="MudBlazor.Severity.Warning" Class="mb-4">
                Debes tener al menos una Cuenta activa y una Categoría creada para poder añadir transacciones.
            </MudAlert>
        }

        <MudForm Model="@model" @ref="@form">
            <MudCardContent>
                <MudTextField @bind-Value="model.Description" For="@(() => model.Description)" Immediately="true"
                              Label="Descripción" Variant="Variant.Outlined" Margin="Margin.Dense" />

                <MudNumericField @bind-Value="model.Amount" For="@(() => model.Amount)" Label="Monto"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" Format="N2"
                                 Culture="@System.Globalization.CultureInfo.CurrentCulture" />

                <MudSelect T="TransactionType?" Value="selectedType" ValueChanged="OnTransactionTypeChanged"
                           Label="Tipo de transacción" Placeholder="Selecciona un tipo..." Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem T="TransactionType?" Value="@((TransactionType?)TransactionType.Income)">Ingreso
                    </MudSelectItem>
                    <MudSelectItem T="TransactionType?" Value="@((TransactionType?)TransactionType.Expense)">Gasto
                    </MudSelectItem>
                </MudSelect>

                <MudDatePicker @bind-Date="transactionDate" Label="Fecha" Variant="Variant.Outlined"
                               Margin="Margin.Dense" />

                <MudSelect T="Guid" @bind-Value="model.AccountId" For="@(() => model.AccountId)" Label="Cuenta"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var account in accounts.Where(a => a.IsActive))
                    {
                        <MudSelectItem T="Guid" Value="@account.Id">@account.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="Guid" @bind-Value="model.CategoryId" For="@(() => model.CategoryId)" Label="Categoría"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(selectedType == null)"
                           Placeholder="Selecciona primero un tipo">
                    @foreach (var category in filteredCategories)
                    {
                        <MudSelectItem T="Guid" Value="@category.Id">@category.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudTextField @bind-Value="model.Reference" For="@(() => model.Reference)" Label="Referencia (Opcional)"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />

                <MudTextField @bind-Value="model.Notes" For="@(() => model.Notes)" Label="Notas (Opcional)"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
            </MudCardContent>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled"
                   Disabled="@(!allCategories.Any() || !accounts.Any(a => a.IsActive))">Create Transaction</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private CreateTransactionDto model = new();
    private MudForm form = null!;
    private List<AccountDto> accounts = new();
    private List<CategoryDto> allCategories = new();
    private IEnumerable<CategoryDto> filteredCategories = Enumerable.Empty<CategoryDto>();

    private DateTime? transactionDate;
    private TransactionType? selectedType;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            var result = await AccountService.GetAllAsync();
            accounts = result.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar cuentas: {ex.Message}", MudSeverity.Error);
        }

        try
        {
            var result = await CategoryService.GetAllAsync();
            allCategories = result.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar categorías: {ex.Message}", MudSeverity.Error);
        }
    }

    private void OnTransactionTypeChanged(TransactionType? newType)
    {
        selectedType = newType;
        model.CategoryId = Guid.Empty; // Reset category selection
        if (newType.HasValue)
        {
            var categoryType = (CategoryType)newType.Value; // El cast es seguro gracias a la comprobación
            filteredCategories = allCategories.Where(c => c.Type == categoryType);
        }
        else
        {
            filteredCategories = Enumerable.Empty<CategoryDto>();
        }
    }

    protected override void OnParametersSet()
    {
        if (transactionDate.HasValue)
        {
            model.Date = transactionDate.Value;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        model.Date = transactionDate ?? DateTime.Today;

        if (selectedType == null)
        {
            Snackbar.Add("Por favor, selecciona un tipo de transacción.", MudSeverity.Warning);
            return;
        }
        model.Type = selectedType.Value;

        var selectedAccount = accounts.FirstOrDefault(a => a.Id == model.AccountId);
        if (selectedAccount != null && selectedAccount.Type == AccountType.Savings && model.Type == TransactionType.Expense)
        {
            Snackbar.Add("No se pueden registrar gastos en una cuenta de Ahorros.", MudSeverity.Error);
            return;
        }

        if (model.CategoryId == Guid.Empty || model.AccountId == Guid.Empty)
        {
            Snackbar.Add("Por favor, selecciona una cuenta y una categoría.", MudSeverity.Warning);
            return;
        }

        await form.Validate();

        if (form.IsValid)
        {
            try
            {
                await TransactionService.CreateAsync(model);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error creating transaction: {ex.Message}", MudSeverity.Error);
            }
        }
    }
}