@using SegundoCerebro.BlazorWasm.Models
@using SegundoCerebro.BlazorWasm.Models.Commands
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Editar tarjeta</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@model" @ref="@form" ValidationDelay="0">
            <MudTextField @bind-Value="model.Name" For="@(() => model.Name)" Label="Nombre de la tarjeta"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudForm>
        <MudAlert Severity="MudSeverity.Info" Class="mt-4">La edición de los detalles de la tarjeta (número, expiración)
            no
            está permitida por seguridad. Solo puedes cambiar el nombre.</MudAlert>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancel">Cancelar</MudButton>
            <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled">Actualizar</MudButton>
        </DialogActions>
    </MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public CardDto CardToEdit { get; set; } = null!;

    private UpdateCardCommand model = new();
    private MudForm form = null!;

    protected override void OnInitialized()
    {
        if (CardToEdit is not null)
        {
            model.Name = CardToEdit.Name;
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        CardToEdit.Name = model.Name;
        Snackbar.Add("Funcionalidad de editar tarjeta pendiente de implementar en el backend.", MudSeverity.Info);
        MudDialog.Close(DialogResult.Ok(CardToEdit));
    }

    void Cancel() => MudDialog.Cancel();
}