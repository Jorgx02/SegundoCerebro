@using SegundoCerebro.BlazorWasm.Models.Commands
@using SegundoCerebro.BlazorWasm.Services
@inject ICardService CardService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IConfiguration Configuration
@implements IAsyncDisposable

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add New Card</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@model" @ref="@form" ValidationDelay="0">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.Name" For="@(() => model.Name)"
                                  Label="Card Name (e.g., 'Personal Visa')" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.CardholderName" For="@(() => model.CardholderName)"
                                  Label="Cardholder Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mb-1">Card Details</MudText>
                    <div id="card-element" class="stripe-card-element">
                        <!-- Stripe Card Element will be mounted here -->
                    </div>
                    <div id="card-errors" role="alert" class="stripe-card-errors"></div>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled" Disabled="processing">
            @if (processing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Processing...</MudText>
            }
            else
            {
                <MudText>Add Card</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid AccountId { get; set; }

    private CreateCardCommand model = new();
    private MudForm form = null!;
    private bool processing = false;
    private DotNetObjectReference<AddCardDialog> objRef = null!;
    private IJSObjectReference? stripeModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. Importa el módulo JS y espera a que esté listo.
            stripeModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/stripe.js");

            objRef = DotNetObjectReference.Create(this);
            var publishableKey = Configuration["Stripe:PublishableKey"];
            if (string.IsNullOrEmpty(publishableKey))
            {
                Snackbar.Add("Stripe Publishable Key is not configured.", MudSeverity.Error);
                return;
            }
            // 2. Llama a las funciones a través de la referencia al módulo.
            await stripeModule.InvokeVoidAsync("initStripe", publishableKey);
            await stripeModule.InvokeVoidAsync("mountCardElement", "card-element");
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        processing = true;
        model.AccountId = AccountId;
        if (stripeModule is not null)
        {
            await stripeModule.InvokeVoidAsync("createPaymentMethod", objRef, model.CardholderName);
        }
    }

    [JSInvokable]
    public async Task OnStripeSuccess(string paymentMethodId)
    {
        model.StripePaymentMethodId = paymentMethodId;
        try
        {
            var newCard = await CardService.CreateAsync(model);
            Snackbar.Add("Card added successfully!", MudSeverity.Success);
            MudDialog.Close(DialogResult.Ok(newCard));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving card: {ex.Message}", MudSeverity.Error);
        }
        finally
        {
            processing = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnStripeError(string errorMessage)
    {
        Snackbar.Add(errorMessage, MudSeverity.Error);
        processing = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    void Cancel() => MudDialog.Cancel();

    public async ValueTask DisposeAsync()
    {
        if (stripeModule is not null)
        {
            await stripeModule.InvokeVoidAsync("unmountCardElement");
            await stripeModule.DisposeAsync();
        }
        objRef?.Dispose();
    }
}