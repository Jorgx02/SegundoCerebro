@using SegundoCerebro.BlazorWasm.Models.Commands
@using SegundoCerebro.BlazorWasm.Services
@inject ICardService CardService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add New Card</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@model" @ref="@form" ValidationDelay="0">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.Name" For="@(() => model.Name)"
                                  Label="Card Name (e.g., 'Personal Visa')" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="model.Brand" For="@(() => model.Brand)" Label="Brand (e.g., 'Visa')"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" HelperText="For demo purposes." />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="model.Last4Digits" For="@(() => model.Last4Digits)" Label="Last 4 Digits"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Counter="4" MaxLength="4"
                                  HelperText="For demo purposes." />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="model.ExpirationMonth" For="@(() => model.ExpirationMonth)"
                                     Label="Exp. Month (MM)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" Max="12" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="model.ExpirationYear" For="@(() => model.ExpirationYear)"
                                     Label="Exp. Year (YYYY)" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Min="@DateTime.Now.Year" />
                </MudItem>
                <MudItem xs="12">
                    <MudAlert Severity="MudBlazor.Severity.Info" Elevation="0">
                        <strong>Note:</strong> In a real application, card details would be securely collected via
                        Stripe Elements, not manual fields. We are mocking this process.
                    </MudAlert>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled">Add Card</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid AccountId { get; set; }

    private CreateCardCommand model = new();
    private MudForm form = null!;

    protected override void OnInitialized()
    {
        model.AccountId = AccountId;
        model.ExpirationYear = DateTime.Now.Year + 3; // Default expiration
    }

    private async Task Submit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        // Mocking the Stripe Payment Method ID for the demo
        model.StripePaymentMethodId = $"pm_{Guid.NewGuid().ToString().Replace("-", "")}";

        try
        {
            var newCard = await CardService.CreateAsync(model);
            Snackbar.Add("Card added successfully!", MudSeverity.Success);
            MudDialog.Close(DialogResult.Ok(newCard));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error adding card: {ex.Message}", MudSeverity.Error);
        }
    }

    void Cancel() => MudDialog.Cancel();
}